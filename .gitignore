# macOS
.DS_Store

# Editor
.idea/
.vscode/
*.swp
*.swo
*~

# Logs
*.log
logs/

# Release signing — the Ed25519 PRIVATE seed used to sign daemon bundles.
# NEVER commit, NEVER serve from the CDN (the daemon pins only the PUBLIC
# key in constants.RELEASE_PUBKEY_HEX). Losing this = mint a new keypair +
# re-pin the pubkey; leaking it = an attacker can sign malicious updates.
.release-signing-key

# Python
__pycache__/
*.pyc
*.pyo
.venv/

# State produced by running the daemon
.meshkore/
state.json

# DM0 — test runner artefacts
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.pre-commit.bak
# bundle output; canonical copy ships under webapp/reference/...
dist/

# Coverage data (parallel per-subprocess files) — confined here
tests/.coverage_cache/
htmlcov/
