{
  "name": "@meshkore/cli",
  "version": "0.5.0",
  "description": "Local daemon CLI that turns a machine into a participant of a MeshKore cluster",
  "license": "MIT",
  "bin": {
    "meshcore": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "build:bin": "bun build src/cli.ts --compile --outfile=bin/meshcore",
    "dev": "tsx src/cli.ts",
    "test": "node --test test/",
    "lint": "tsc --noEmit",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "ws": "^8.18.0",
    "yaml": "^2.6.0",
    "zod": "^3.23.0",
    "simple-git": "^3.27.0",
    "chalk": "^5.3.0",
    "chokidar": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
